{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "background": "transparent",
  "description": "A basic grouped bar chart example.",
  "width": 400,
  "height": 240,
  "padding": 5,
  "title":{"text":"Year to get permanent visa by first visa type", "fontSize":20},
  "data": {
        "name": "table",
      "url": "data/time_to_permanent.csv",
      "format": {"type": "csv"}
    },

  "scales": [
    {
      "name": "xscale",
      "type": "band",
      "domain": {"data": "table", "field": "Time_to_permanent"},
      "range": "width",
      "padding": 0.2
    },
    {
      "name": "yscale",
      "type": "linear",
      "domain": {"data": "table", "field": "percent"},
      "range": "height",
      "round": true,
      "zero": true,
      "nice": true
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "table", "field": "visa"},
      "range": {"scheme": "category20"}
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "xscale",
      "tickSize": 0,
      "labelPadding": 4,
      "zindex": 1,
      "labelAngle": 45,
      "labelAlign": "left",
      "title": "years to permanentship"
    },
    {
      "orient": "left",
      "scale": "yscale",
      "title": "%"
    }
  ],

  "legends": [
    {
      "fill": "color",
      "title": "Visa Type",
      "orient": "top-right",
      "offset": 8
    }
  ],

  "marks": [
    {
      "type": "group",

      "from": {
        "facet": {
          "data": "table",
          "name": "facet",
          "groupby": "Time_to_permanent"
        }
      },

      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "Time_to_permanent"}
        }
      },

      "signals": [
        {"name": "width", "update": "bandwidth('xscale')"}
      ],

      "scales": [
        {
          "name": "pos",
          "type": "band",
          "range": "width",
          "domain": {"data": "facet", "field": "visa"}
        }
      ],

      "marks": [
        {
          "name": "bars",
          "from": {"data": "facet"},
          "type": "rect",
          "encode": {
            "enter": {
              "x": {"scale": "pos", "field": "visa"},
              "width": {"scale": "pos", "band": 1},
                "y": {"scale": "yscale", "field": "percent"},
                "y2": {"scale": "yscale", "value": 0},
                "fill": {"scale": "color", "field": "visa"},
                "tooltip": {"signal": "datum.visa + ': ' + format(datum.percent, '.1f') + '%'"}
            }
          }
        }
      ]
    }
  ]
}
