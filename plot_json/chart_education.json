{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "background": "transparent",
  "description": "Four donut charts, one per visa type.",
  "data": {
    "url": "data/chart_education.csv"
  },
  "title":{"text":"Percentage of higher education achievement by visa type"},
  "transform": [
    {
      "calculate": "indexof(['Postgraduate degree', 'Bachelor degree', 'Graduate diploma and graduate certificate', 'Advanced diploma and diploma', 'Certificate III & IV'], datum.degree) >= 0 ? datum.degree : 'Lower education'",
      "as": "education_group"
    },
    {
      "aggregate": [
        {"op": "sum", "field": "value", "as": "value"}
      ],
      "groupby": ["visa", "education_group"]
    },
    {
      "joinaggregate": [{"op": "sum", "field": "value", "as": "total"}],
      "groupby": ["visa"]
    },
    {
      "calculate": "datum.value / datum.total",
      "as": "percent"
    },
    {
      "calculate": "indexof(['Bachelor degree','Advanced diploma and diploma','Postgraduate degree','Certificate III & IV','Graduate diploma and graduate certificate','Lower education'], datum.education_group)",
      "as": "education_order"
    }
  ],

  "facet": {
    "field": "visa",
    "type": "nominal",
    "columns": 4
  },

  "spec": {
    "layer": [
      {
        "mark": {"type": "arc", "innerRadius": 50},
        "encoding": {
          "theta": {"field": "value", "type": "quantitative", "stack":"normalize"},
          "color": {
            "field": "education_group", "type": "nominal",
            "scale": {
              "domain": [
                "Bachelor degree",
                "Advanced diploma and diploma",
                "Postgraduate degree",
                "Certificate III & IV",
                "Graduate diploma and graduate certificate",
                "Lower education"
              ],
              "range": [
                "#F95D6A",
                "#FF7C43",
                "#FFA600",
                "#118AB2",
                "#2F4B7C",
                "#BDBDBD"
              ]
            },
            "legend": {
              "title": "Education Level",
              "orient": "top",
              "offset": 0
            }
          },
          "order": {
            "field": "education_order",
            "type": "quantitative",
            "sort": "ascending"
          },
          "tooltip": [
            {"field": "education_group", "type": "nominal"},
            {"field": "percent", "type": "quantitative", "format": ".1%"}
          ]
        }
      },
      {
        "transform": [
          {"filter": "datum.education_group === 'Lower education'"},
          {"calculate": "1 - datum.percent", "as": "remaining_percent"}
        ],
        "mark": {
          "type": "text",
          "align": "center",
          "baseline": "middle",
          "fontSize": 20,
          "fontWeight": "bold"
        },
        "encoding": {
          "text": {"field": "remaining_percent", "type": "quantitative", "format": ".1%"}
        }
      }
    ]
  }
}
