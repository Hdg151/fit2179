{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "data": { "url": "data/immi_global_top.csv" },
  "width": 400,
  "height":300,
  "title": { "text": "Countries with top immigrant count", "fontSize":20 },
  "config": {
    "range": {
        "category": [
            "#2F4B7C",
            "#665191",
            "#A05195",
            "#D45087",
            "#F95D6A",
            "#FF7C43",
            "#FFA600"
        ]
    }
  },

  "transform": [
    { "filter": "datum.Country != \"World\" && datum.Country != \"India\"" },
    {
      "calculate": "datum.Country == 'Australia' ? 'Australia' : 'Other'",
      "as": "highlight"
    }
  ],
  "layer": [
    {
      "mark": "circle",
      "encoding": {
        "y": {
          "field": "Country",
          "type": "nominal",
          "title": "Country",
          "axis": {
            "labelColor": {
              "condition": {
                "test": "datum.value == 'Australia'",
                "value": "#e6820a"
              },
              "value": "gray"
            },
            "labelFontWeight": {
              "condition": {
                "test": "datum.value == 'Australia'",
                "value": "bold"
              },
              "value": "normal"
            }
          }
        },
        "x": {
          "field": "million_2024",
          "type": "quantitative",
          "title": "Total Immigrants (millions)"
        },
        "size": {
          "field": "percent_2024",
          "type": "quantitative",
          "title": "Normalised immigrant percents",
         "legend": {
            "orient": "top-right",
            "offset": 0
        }
        },
        "tooltip": [
          {"field":"Country","type":"nominal"},
          {"field":"million_2024","type":"quantitative","title":"Total Immigrant (millions)"},
          {"field":"percent_2024","type":"quantitative","title":"% of immigrant in population"}
        ],
        "color": {
          "field": "highlight",
          "type": "nominal",
          "scale": {
            "domain": ["Australia", "Other"],
            "range": ["#e6820a", "#2F4B7C"]
          },
          "legend": null
        }
      }
    }
  ]
}