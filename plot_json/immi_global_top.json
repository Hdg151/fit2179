{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
        "url": "data/immi_global_top.csv"
    },
    "width": 600,
    "title": { "text": "Countries with top immigrant count" },

    "transform":[{"filter": "datum.Country != \"World\" && datum.Country != \"India\""}],

    "layer": [
        {
            "mark": "circle",
            "encoding": {
                "x": {
                    "field": "pop_2024", "type": "quantitative",
                    "title":"Total Population",
                    "scale":{"type":"log"}
                },
                "y": {
                    "field": "million_2024", "type":"quantitative",
                    "title":"Immigrants (millions)",
                    "scale": {"type":"log"}
                },
                "size": { "field": "percent_2024", "type": "quantitative", "title":"Immigrants (percents)"}
            }
        },
        {
            "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 3
            },
            "encoding": {
                "x": {
                    "field": "pop_2024", "type": "quantitative",
                    "title":"Total Population",
                    "scale":{"type":"log"}
                },
                "y": {
                    "field": "million_2024", "type":"quantitative",
                    "title":"Immigrants (millions)",
                    "scale": {"type":"log"}
                },
                "text": {"field":"Country","type":"nominal"},
                "color": {"field": "Country", "type": "nominal"}
            }
        }
    ]
}