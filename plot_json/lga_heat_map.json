{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "transparent",
  "title": {
    "text": "Percent of overseas born population - Australian Local Government Area (LGA)",
    "anchor": "middle"
  },
  "width": 550,
  "height": 550,
  "projection": {
    "type": "mercator",
    "center": [134, -25],
    "scale": {"signal": "1.2 * min(width, height)"},
    "translate": {"signal": "[width / 2, height / 2]"}
  },
  "data": {
    "url": "LGA_2025_AUST_GDA2020.json",
    "format": {"type": "topojson", "feature": "LGA_2025_AUST_GDA2020"}
  },
  "transform": [
    {
      "lookup": "properties.LGA_CODE25",
      "from": {
        "data": {
          "url": "data/lga_heat_map.csv",
          "format": { "type": "csv" },
          "transform": [
            { "filter": "datum.Year === '2021'" }
          ]
        },
        "key": "Code",
        "fields": ["Total_born_overseas","Label"]
      }
    }
  ],
  "mark": {"type": "geoshape",
          "stroke": "#666666",
          "strokeWidth": 0.3},
  "encoding": {
    "color": {
      "field": "Total_born_overseas",
      "type": "quantitative",
      "scale": {
        "type": "threshold",
        "domain": [5, 10, 15, 25],
        "zero": true,
        "range": ["#f7fbff", "#c6dbef", "#6baed6", "#3182bd", "#08519c"]
      },
      "legend": {
        "orient": "top-right",
        "direction": "vertical",
        "title": "Total born overseas",
        "titleAlign": "right",
        "titleAnchor": "end",
        "values": [0, 5, 10, 15, 25]
      }
    },
    "tooltip": [
      {"field": "Label", "type": "nominal", "title": "State"},
      {"field": "Total_born_overseas", "type": "quantitative"}
    ]
  }
}