{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
        "url": "data/line_stacked_bars.csv"
    },
    "width": 600,
    "title": { "text": "Australian immigrants - Arrival and Departure" },

    "transform": [
        {"calculate": "datum.name == \"Departure\" ? -datum.value : datum.value", "as": "value"}
    ],

    "encoding": {
        "x": { "field": "Year", "type": "ordinal", "title":"Year"}        
    },
    "layer": [
        {
            "mark":"bar",
            "encoding":{
                "y": {
                        "field": "value", "type": "quantitative", "title": "People"
                     },
                "color": {"field":"name", "type": "nominal", "title":"Origin"}
            }
        },
        {
            "mark": {"type":"line", "color": "#000000"},
            "encoding":{
                "y": {"field":"Net", "aggregate":"min"}
            }
        }
    ]
}