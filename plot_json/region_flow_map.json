{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Region of immigrant arrival to Australia",
  "width": 800,
  "height": 400,
  "projection": {
    "type": "EqualEarth",
    "rotate": [-150, 0, 0]
  },
  "data": {
    "url": "ne_110m_admin_0_countries.json",
    "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
  },
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "fill": "#d9d9d9",
        "stroke": "white",
        "strokeWidth": 0.5,
        "tooltip": null
      }
    },
    {
      "transform": [
        {
          "lookup": "properties.region",
          "from": {
            "data": {
              "url": "data/thumbnail_world_region_arrival.csv",
              "format": {"type": "csv"}
            },
            "key": "region",
            "fields": ["no_2024"]
          }
        },
        {"filter": "isValid(datum.no_2024)"}
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "no_2024",
          "type": "quantitative",
          "scale": {"zero": true}
        },
        "tooltip": [
          {"field": "properties.region", "type": "nominal", "title": "Region"},
          {"field": "no_2024", "type": "quantitative", "title": "Arrivals (2024)"}
        ]
      }
    }
  ]
}