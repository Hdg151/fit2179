{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 300,
  "height": 200,
  "projection": {
    "type": "EqualEarth",
    "rotate": [-150, 0, 0]
  },
  "data": {
    "url": "ne_110m_admin_0_countries.json",
    "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
  },
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "fill": "#d9d9d9",
        "stroke": "white",
        "strokeWidth": 0.5,
        "tooltip": null
      }
    },
    {
      "transform": [
        {
          "lookup": "properties.region",
          "from": {
            "data": {
              "url": "data/region_map.csv",
              "format": {"type": "csv"}
            },
            "key": "region",
            "fields": ["no_2024"]
          }
        },
        {"filter": "isValid(datum.no_2024)"}
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "properties.region",
          "type": "nominal",
          "scale": {
            "domain": [
              "North-West Europe",
              "South-East Asia",
              "Southern & Central Asia",
              "Southern & Eastern Europe",
              "Sub-Saharan Africa",
              "North-East Asia",
              "North Africa & Middle East",
              "Americas",
              "Oceania (ex Aust. born)"
            ],
            "range": [
              "#88CCEE",
              "#DDCC77",
              "#FE6100",
              "#AA4499",
              "#332288",
              "#CC6677",
              "#111111",
              "#999999",
              "#666666"
            ]
          },
          "legend":null
        },
        "tooltip": [
          {"field": "properties.region", "type": "nominal", "title": "Region"}
        ]
      }
    }
  ]
}