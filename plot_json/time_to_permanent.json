{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "description": "A basic grouped bar chart example.",
  "width": 300,
  "height": 240,
  "padding": 5,

  "data": {
        "name": "table",
      "url": "data/time_to_permanent.csv",
      "format": {"type": "csv"}
    },

  "scales": [
    {
      "name": "xscale",
      "type": "band",
      "domain": {"data": "table", "field": "Time_to_permanent"},
      "range": "width",
      "padding": 0.2
    },
    {
      "name": "yscale",
      "type": "linear",
      "domain": {"data": "table", "field": "percent"},
      "range": "height",
      "round": true,
      "zero": true,
      "nice": true
    },
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "table", "field": "visa"},
      "range": {"scheme": "category20"}
    }
  ],

  "axes": [
    {"orient": "bottom", "scale": "xscale", "tickSize": 0, "labelPadding": 4, "zindex": 1},
    {"orient": "left", "scale": "yscale"}
  ],

  "marks": [
    {
      "type": "group",

      "from": {
        "facet": {
          "data": "table",
          "name": "facet",
          "groupby": "Time_to_permanent"
        }
      },

      "encode": {
        "enter": {
          "x": {"scale": "xscale", "field": "Time_to_permanent"}
        }
      },

      "signals": [
        {"name": "width", "update": "bandwidth('xscale')"}
      ],

      "scales": [
        {
          "name": "pos",
          "type": "band",
          "range": "width",
          "domain": {"data": "facet", "field": "visa"}
        }
      ],

      "marks": [
        {
          "name": "bars",
          "from": {"data": "facet"},
          "type": "rect",
          "encode": {
            "enter": {
              "x": {"scale": "pos", "field": "visa"},
              "width": {"scale": "pos", "band": 1},
              "y": {"scale": "yscale", "field": "percent"},
              "y2": {"scale": "yscale", "value": 0},
              "fill": {"scale": "color", "field": "visa"}
            }
          }
        }
      ]
    }
  ]
}
